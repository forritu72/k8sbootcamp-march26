# Server Configuration
PORT=8006
FLASK_ENV=development

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# SMTP Configuration
# Default targets the in-cluster Mailpit sink. For local dev outside the
# cluster, run mailpit (`brew install mailpit && mailpit`) and use localhost.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_SENDER_EMAIL=noreply@ecommerce.local
SMTP_SENDER_NAME=E-Commerce Platform

# Logging
LOG_LEVEL=INFO
