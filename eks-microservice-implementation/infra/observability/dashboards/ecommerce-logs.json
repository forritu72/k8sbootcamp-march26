        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "search",
        "name": "search",
        "options": [{ "selected": true, "text": "", "value": "" }],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
