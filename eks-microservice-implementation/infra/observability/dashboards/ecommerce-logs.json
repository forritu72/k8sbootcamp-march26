      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "",
        "hide": 0,
        "includeAll": true,
        "label": "app",
        "multi": true,
        "name": "app",
        "options": [],
        "query": { "label": "app", "refId": "LokiVariableQueryEditor-VariableQuery", "stream": "{namespace=\"$namespace\"}", "type": 1 },
        "refresh": 2,
        "regex": "",
