  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ecommerce — Logs (Loki)",
  "uid": "ecommerce-logs",
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Log volume by app",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60 } } },
      "options": { "legend": { "displayMode": "table", "placement": "right" } },
      "targets": [
        { "expr": "sum by (app) (count_over_time({namespace=\"$namespace\", app=~\"$app\"} |~ \"(?i)$search\" [1m]))", "legendFormat": "{{app}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error log rate (level=error|fatal, status=5xx)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        {
          "expr": "sum by (app) (rate({namespace=\"$namespace\", app=~\"$app\"} |~ \"(?i)error|fatal|panic|exception|\\\" 5\\\\d{2} \" [5m]))",
          "legendFormat": "{{app}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Live tail",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 12 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        { "expr": "{namespace=\"$namespace\", app=~\"$app\"} |~ \"(?i)$search\"", "refId": "A" }
      ]
    },
    {
      "type": "logs",
      "title": "Errors only",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 28 },
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "exact",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "expr": "{namespace=\"$namespace\", app=~\"$app\"} |~ \"(?i)error|fatal|panic|exception|\\\" 5\\\\d{2} \"",
          "refId": "A"
        }
      ]
    }
  ]
}
